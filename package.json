{
  "name": "alertabarrio",
  "version": "1.0.0",
  "description": "Civic urban reporting platform for Lima, Peru — React + Node.js + AI",
  "scripts": {
    "install:all": "npm install && cd client && npm install",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "start": "node server/index.js"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "keywords": ["react", "nodejs", "civic-tech", "maps", "lima", "peru", "ai", "full-stack"],
  "author": "Dakoyzu",
  "license": "MIT"
}
